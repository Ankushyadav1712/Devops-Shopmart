{
  "name": "shopmart-server",
  "version": "1.0.0",
  "description": "ShopMart Backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "seed": "node seed.js",
    "test": "jest --verbose --runInBand --watchman=false",
    "test:ci": "jest --runInBand --watchman=false --ci --coverage --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "mongoose": "^9.3.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.2.2"
  },
  "jest-junit": {
    "outputDirectory": "reports",
    "outputName": "junit.xml",
    "ancestorSeparator": " › ",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}"
  }
}
